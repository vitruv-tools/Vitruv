#!/bin/bash
#
# Git post-merge hook for Vitruvius V-SUM merge validation
#
# Triggered after every merge or pull. Validates that the merged V-SUM is consistent.
# This is non-blocking: the merge has already completed, so inconsistencies are
# reported as warnings rather than blocking the operation.
#
# Workflow:
#   1. Detect if this is a fast-forward merge (skip if so - follow Git's behavior)
#   2. Get merge commit SHA, source branch, and target branch
#   3. Generate unique request ID and create merge trigger file
#   4. Wait for VsumMergeWatcher to process and write results
#   5. Display validation result and always exit 0 (never blocks)
#

set -e

# Git passes one argument: 1 if squash merge, 0 for normal merge
SQUASH_MERGE=$1

REPO_ROOT=$(git rev-parse --show-toplevel)
TARGET_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached-HEAD")
MERGE_COMMIT_SHA=$(git rev-parse HEAD)

# Detect fast-forward merges and skip validation
# Git doesn't create a merge commit for fast-forward merges, so we follow
# the same principle and don't create merge metadata.
# Detection: check if HEAD has a second parent (HEAD^2)

if ! git rev-parse HEAD^2 &>/dev/null; then
    echo "Fast-forward merge completed"
    echo "Git did not create a merge commit (linear history)"
    echo "No merge metadata will be generated (following Git's behavior)"
    echo ""
    echo "To force merge commits: git merge --no-ff <branch>"
    exit 0
fi

echo "Merge commit detected"
echo "Merge SHA: ${MERGE_COMMIT_SHA:0:8}"

# Determine source branch (the branch that was merged in)
SOURCE_COMMIT=$(git rev-parse HEAD^2)
SOURCE_BRANCH=$(git name-rev --name-only "$SOURCE_COMMIT" 2>/dev/null || echo "unknown-branch")
SOURCE_BRANCH=$(echo "$SOURCE_BRANCH" | sed 's|^remotes/origin/||')

# Vitruvius directory
VITRUVIUS_DIR="$REPO_ROOT/.vitruvius"
mkdir -p "$VITRUVIUS_DIR"

# Generate unique request ID for this merge validation
if command -v uuidgen &> /dev/null; then
    REQUEST_ID=$(uuidgen)
elif [ -f /proc/sys/kernel/random/uuid ]; then
    REQUEST_ID=$(cat /proc/sys/kernel/random/uuid)
else
    REQUEST_ID="$(date +%s)-$$-$RANDOM"
fi

# File paths
TRIGGER_FILE="$VITRUVIUS_DIR/merge-trigger"
RESULT_FILE="$VITRUVIUS_DIR/merge-result-$REQUEST_ID"
RESULT_JSON="$VITRUVIUS_DIR/merge-result-$REQUEST_ID.json"

echo "Validating merged V-SUM state..."
echo "Request ID:    $REQUEST_ID"
echo "Merge commit:  ${MERGE_COMMIT_SHA:0:8}"
echo "Source:        $SOURCE_BRANCH"
echo "Target:        $TARGET_BRANCH"
echo ""

# Create merge trigger file
TIMESTAMP=$(date +%s)
echo "$MERGE_COMMIT_SHA|$SOURCE_BRANCH|$TARGET_BRANCH|$REQUEST_ID|$TIMESTAMP" > "$TRIGGER_FILE"

MAX_WAIT=60
WAITED=0

while [ $WAITED -lt $MAX_WAIT ]; do
    if [ -f "$RESULT_FILE" ]; then
        # Result file exists - display it
        echo ""
        cat "$RESULT_FILE"
        echo ""

        # Check if there were errors
        if grep -qi "error\|failed" "$RESULT_FILE"; then
            echo "The merge has completed, but the model may need attention."
            echo "Review the inconsistencies above and resolve them in a follow-up commit."
            echo ""
        fi

        echo "Merge metadata saved to .vitruvius/merges/${MERGE_COMMIT_SHA:0:7}.metadata"
        echo ""

        # Clean up result files
        rm -f "$RESULT_FILE" "$RESULT_JSON"

        exit 0
    fi

    # Wait 0.5 seconds before checking again
    sleep 0.5
    WAITED=$((WAITED + 1))

    # Show progress every 5 seconds
    if [ $((WAITED % 10)) -eq 0 ]; then
        ELAPSED=$((WAITED / 2))
        echo "Still waiting for merge validation... (${ELAPSED}s elapsed)"
    fi
done

echo "Merge validation timeout after $((MAX_WAIT / 2)) seconds"
echo ""
echo "Request ID: $REQUEST_ID"
echo ""
echo "The merge has completed successfully, but post-merge validation could not finish."
echo ""
echo "Possible causes:"
echo "  - VsumMergeWatcher is not running"
echo "  - Validation is taking longer than expected"
echo "  - Another merge validation is in progress (lock contention)"
echo "  - Java application is not responding"
echo ""
echo "Please ensure:"
echo "  1. Your Vitruvius application is running"
echo "  2. VsumMergeWatcher has been started"
echo "  3. Check logs for errors related to request ID: $REQUEST_ID"
echo ""
echo "You may want to manually verify the merged V-SUM state."

# Clean up
rm -f "$TRIGGER_FILE"
rm -f "$RESULT_FILE" "$RESULT_JSON"

# Always exit 0 - merge is already complete and cannot be undone
exit 0