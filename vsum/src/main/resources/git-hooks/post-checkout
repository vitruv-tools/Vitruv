#!/bin/bash
#
# Git post-checkout hook for Vitruvius VSUM reload and branch metadata tracking
#
# This hook is triggered after:
#   - Branch switches (git checkout <branch>, git switch <branch>)
#   - New branch creation (git checkout -b <branch>, git switch -c <branch>)
#   - File checkouts (git checkout -- <file>)
#
# Arguments passed by Git:
#   $1 = previous HEAD ref
#   $2 = new HEAD ref
#   $3 = flag: 1 = branch checkout, 0 = file checkout
#
# For branch operations, this hook:
#   1. Writes a reload trigger file to signal VsumReloadWatcher
#   2. Writes branch metadata if a new branch was created
#

# Get repository root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Get hook arguments
PREV_HEAD=$1
NEW_HEAD=$2
BRANCH_FLAG=$3

# Only process branch checkouts, not file checkouts
if [ "$BRANCH_FLAG" != "1" ]; then
    exit 0
fi

# Get the new branch name
NEW_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached-HEAD")

# Vitruvius directory
VITRUVIUS_DIR="$REPO_ROOT/.vitruvius"
BRANCHES_DIR="$VITRUVIUS_DIR/branches"

# Ensure .vitruvius directories exist
mkdir -p "$VITRUVIUS_DIR"
mkdir -p "$BRANCHES_DIR"


# STEP 1: Write reload trigger (always, for every branch switch)

TRIGGER_FILE="$VITRUVIUS_DIR/reload-trigger"
echo "$NEW_BRANCH" > "$TRIGGER_FILE"


# STEP 2: Create branch metadata if this is a new branch

# Detect if this is a new branch by checking if metadata already exists
METADATA_FILE="$BRANCHES_DIR/$NEW_BRANCH.metadata"

if [ ! -f "$METADATA_FILE" ]; then
    # This is a new branch - need to create metadata

    # Special case: master/main branch is the root branch (no parent)
    if [ "$NEW_BRANCH" == "master" ] || [ "$NEW_BRANCH" == "main" ]; then
        PARENT_BRANCH="none"
        echo "Vitruvius: Creating metadata for root branch '$NEW_BRANCH'"
    else
        # Determine parent branch from git reflog
        # When you run "git checkout -b new-branch", reflog shows:
        # "checkout: moving from <parent> to new-branch"
        PARENT_BRANCH=$(git reflog -1 | grep -oP "checkout: moving from \K[^ ]+" || echo "unknown")

        # If reflog detection failed, use unknown
        if [ -z "$PARENT_BRANCH" ]; then
            PARENT_BRANCH="unknown"
        fi

        echo "Vitruvius: Branch metadata created for '$NEW_BRANCH' (parent: '$PARENT_BRANCH')"
    fi

    # Get commit SHA (unique identifier for this branch)
    COMMIT_SHA=$(git rev-parse HEAD)
    SHORT_SHA="${COMMIT_SHA:0:7}"

    # Get current timestamp in ISO 8601 format
    # Try different date command formats for cross-platform compatibility
    if date -Iseconds >/dev/null 2>&1; then
        TIMESTAMP=$(date -Iseconds)
    else
        # Fallback for systems without -Iseconds (e.g., macOS)
        TIMESTAMP=$(date +"%Y-%m-%dT%H:%M:%S%z")
    fi

    # Write metadata file in JSON format (matching BranchMetadata.java structure)
    cat > "$METADATA_FILE" << EOF
{
  "branchName": "$NEW_BRANCH",
  "uniqueId": "$SHORT_SHA",
  "state": "ACTIVE",
  "parentBranch": "$PARENT_BRANCH",
  "createdAt": "$TIMESTAMP",
  "lastModified": "$TIMESTAMP"
}
EOF

git add "$METADATA_FILE" 2>/dev/null || true

else
    :
fi

exit 0