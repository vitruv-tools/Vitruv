#!/bin/bash
#
# Git post-checkout hook for Vitruvius VSUM branch switching
#

PREVIOUS_HEAD=$1
NEW_HEAD=$2
BRANCH_SWITCH=$3

if [ "$BRANCH_SWITCH" != "1" ]; then
    exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
NEW_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached-HEAD")

VITRUVIUS_DIR="$REPO_ROOT/.vitruvius"
mkdir -p "$VITRUVIUS_DIR"

METADATA_FILE="$VITRUVIUS_DIR/branches/$NEW_BRANCH.metadata"

if [ ! -f "$METADATA_FILE" ]; then
    echo "Vitruvius: Creating metadata for new branch '$NEW_BRANCH'..."

    mkdir -p "$VITRUVIUS_DIR/branches"

    # Determine parent branch
    if [ "$NEW_BRANCH" = "master" ] || [ "$NEW_BRANCH" = "main" ]; then
        # Root branches are their own parent
        PARENT_BRANCH="$NEW_BRANCH"
    else
        # FIXED: Use reflog to find where we came from
        # Format: "checkout: moving from <parent> to <new>"
        PARENT_BRANCH=$(git reflog -1 --format="%gs" | sed -n 's/checkout: moving from \(.*\) to .*/\1/p')

        # Clean up branch name (remove remotes/, tags/, etc.)
        PARENT_BRANCH=$(echo "$PARENT_BRANCH" | sed 's|^remotes/origin/||' | sed 's|^refs/heads/||')

        # Fallback to master if empty or looks like a SHA
        if [ -z "$PARENT_BRANCH" ] || [[ "$PARENT_BRANCH" =~ ^[0-9a-f]{7,40}$ ]]; then
            PARENT_BRANCH="master"
        fi
    fi

    TIMESTAMP=$(date -Iseconds 2>/dev/null || date +%Y-%m-%dT%H:%M:%S)

    cat > "$METADATA_FILE" << EOF
{
  "branchName": "$NEW_BRANCH",
  "state": "ACTIVE",
  "parentBranch": "$PARENT_BRANCH",
  "createdAt": "$TIMESTAMP",
  "lastModified": "$TIMESTAMP"
}
EOF

    echo "Metadata created: $NEW_BRANCH.metadata (parent: $PARENT_BRANCH)"
    git add "$METADATA_FILE" 2>/dev/null || true
fi

if command -v uuidgen &> /dev/null; then
    REQUEST_ID=$(uuidgen)
elif [ -f /proc/sys/kernel/random/uuid ]; then
    REQUEST_ID=$(cat /proc/sys/kernel/random/uuid)
else
    REQUEST_ID="$(date +%s)-$$-$RANDOM"
fi

TIMESTAMP=$(date +%s)
TRIGGER_FILE="$VITRUVIUS_DIR/reload-trigger"
echo "$NEW_BRANCH|$REQUEST_ID|$TIMESTAMP|$PARENT_BRANCH" > "$TRIGGER_FILE"
echo "Vitruvius: Branch switched from '$PARENT_BRANCH' to '$NEW_BRANCH'"
echo "VSUM will reload to reflect the checked-out branch"

exit 0