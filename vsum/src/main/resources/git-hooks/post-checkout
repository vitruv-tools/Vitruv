#!/bin/bash
#
# Git post-checkout hook for Vitruvius VSUM branch switching.
#
# Responsibilities: detect branch switches and write a reload trigger file.
# Branch metadata creation is handled by PostCheckoutHandler (Java side).
#

PREVIOUS_HEAD=$1
NEW_HEAD=$2
BRANCH_SWITCH=$3

if [ "$BRANCH_SWITCH" != "1" ]; then
    exit 0
fi

REPO_ROOT=$(git rev-parse --show-toplevel)
NEW_BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached-HEAD")

VITRUVIUS_DIR="$REPO_ROOT/.vitruvius"
mkdir -p "$VITRUVIUS_DIR"

# Determine the old branch from the reflog so it can be passed in the trigger file.
# The Java PostCheckoutHandler uses this to initialise the new branch's VSUM state
# from the correct parent and to create metadata when the branch was created via CLI.
if [ "$NEW_BRANCH" = "master" ] || [ "$NEW_BRANCH" = "main" ]; then
    OLD_BRANCH="$NEW_BRANCH"
else
    OLD_BRANCH=$(git reflog -1 --format="%gs" | sed -n 's/checkout: moving from \(.*\) to .*/\1/p')
    OLD_BRANCH=$(echo "$OLD_BRANCH" | sed 's|^remotes/origin/||' | sed 's|^refs/heads/||')
    if [ -z "$OLD_BRANCH" ] || [[ "$OLD_BRANCH" =~ ^[0-9a-f]{7,40}$ ]]; then
        OLD_BRANCH="master"
    fi
fi

if command -v uuidgen &> /dev/null; then
    REQUEST_ID=$(uuidgen)
elif [ -f /proc/sys/kernel/random/uuid ]; then
    REQUEST_ID=$(cat /proc/sys/kernel/random/uuid)
else
    REQUEST_ID="$(date +%s)-$$-$RANDOM"
fi

TIMESTAMP=$(date +%s)
TRIGGER_FILE="$VITRUVIUS_DIR/reload-trigger"
echo "$NEW_BRANCH|$REQUEST_ID|$TIMESTAMP|$OLD_BRANCH" > "$TRIGGER_FILE"
echo "Vitruvius: Branch switched from '$OLD_BRANCH' to '$NEW_BRANCH'"
echo "VSUM will reload to reflect the checked-out branch"

exit 0
