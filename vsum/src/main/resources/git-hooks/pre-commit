#!/bin/bash
#
# Git pre-commit hook for Vitruvius V-SUM validation
#
# This hook is triggered before every commit and validates that the V-SUM
# is in a consistent state. If validation fails, the commit is blocked.
#
# Installation:
#   This script is automatically installed by GitHookInstaller.java
#
# How it works:
#   1. Gets current commit SHA and branch name
#   2. Creates a validation trigger file
#   3. Waits for VsumValidationWatcher to process and write results
#   4. Reads validation result and allows/blocks commit accordingly
#

set -e  # Exit on error

# Get repository root
REPO_ROOT=$(git rev-parse --show-toplevel)

# Get commit information
# Note: For pre-commit, HEAD is the previous commit, so we use the current branch
BRANCH=$(git symbolic-ref --short HEAD 2>/dev/null || echo "detached-HEAD")

# For pre-commit, we need to get the SHA of what WILL be committed
# We'll use a placeholder for now and let the watcher generate it
COMMIT_SHA=$(git rev-parse HEAD 2>/dev/null || echo "0000000000000000000000000000000000000000")

# Vitruvius directory
VITRUVIUS_DIR="$REPO_ROOT/.vitruvius"

# Ensure .vitruvius directory exists
mkdir -p "$VITRUVIUS_DIR"

# File paths
TRIGGER_FILE="$VITRUVIUS_DIR/validate-trigger"
RESULT_FILE="$VITRUVIUS_DIR/validation-result"
RESULT_JSON="$VITRUVIUS_DIR/validation-result.json"

echo "Validating V-SUM consistency..."
echo ""

# Create validation trigger file
echo "$COMMIT_SHA|$BRANCH" > "$TRIGGER_FILE"

# Wait for validation result (max 10 seconds = 20 iterations * 0.5s)
MAX_WAIT=20
WAITED=0

while [ $WAITED -lt $MAX_WAIT ]; do
    if [ -f "$RESULT_FILE" ]; then
        # Result file exists - read it

        # Read first line to get status
        STATUS=$(head -n 1 "$RESULT_FILE")

        if [ "$STATUS" = "VALID" ]; then
            # Validation passed
            echo "✓ V-SUM validation PASSED"
            echo ""

            # Show any warnings if present
            # shellcheck disable=SC2046
            if [ $(wc -l < "$RESULT_FILE") -gt 3 ]; then
                tail -n +4 "$RESULT_FILE"
                echo ""
            fi

            # Clean up result files
            rm -f "$RESULT_FILE" "$RESULT_JSON"

            exit 0  # Allow commit

        else
            # Validation failed
            echo "✗ V-SUM validation FAILED"
            echo ""

            # Display full error report
            cat "$RESULT_FILE"
            echo ""

            # Clean up result files
            rm -f "$RESULT_FILE" "$RESULT_JSON"

            echo "Commit blocked. Please fix errors above before committing."
            exit 1  # Block commit
        fi
    fi

    # Wait 0.5 seconds before checking again
    sleep 0.5
    WAITED=$((WAITED + 1))
done

# Timeout - validation took too long or watcher not running
echo "⚠ Validation timeout after ${MAX_WAIT} seconds"
echo ""
echo "Possible causes:"
echo "  - VsumValidationWatcher is not running"
echo "  - Validation is taking longer than expected"
echo "  - Java application is not responding"
echo ""
echo "Please ensure:"
echo "  1. Your Vitruvius application is running"
echo "  2. VsumValidationWatcher has been started"
echo "  3. Check logs for any errors"
echo ""
echo "Commit blocked for safety."

# Clean up trigger file if still exists
rm -f "$TRIGGER_FILE"

exit 1  # Block commit on timeout